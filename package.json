{
  "name": "db-sync-manager",
  "version": "0.1.0",
  "description": "MySQL/MariaDB 데이터베이스 비교 및 동기화 도구",
  "type": "module",
  "license": "MIT",
  "main": "dist-app/app/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:it": "vitest run --config vitest.config.it.ts",
    "app:build": "tsc -p tsconfig.app.json && node app/copy-renderer.mjs",
    "app:start": "npm run app:build && electron ."
  },
  "keywords": [
    "mysql",
    "mariadb",
    "database",
    "sync",
    "diff",
    "migration",
    "dump"
  ],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^33.4.11",
    "mysql-memory-server": "^1.14.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "mysql2": "^3.23.0"
  }
}
